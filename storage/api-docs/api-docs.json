{
    "openapi": "3.0.0",
    "info": {
        "title": "Virtigia Map Editor API",
        "description": "Token do autoryzacji wygenerujesz w panelu użytkownika: Profil -> Tokeny API.",
        "version": "1.0.0"
    },
    "paths": {
        "/api/v1/maps": {
            "get": {
                "tags": [
                    "Maps"
                ],
                "summary": "Pobranie listy map (bez ciężkiego pola col)",
                "operationId": "getMapsList",
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "description": "Liczba rekordów na stronę (1-100)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 50
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginowana lista map",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/App\\Http\\Resources\\MapListCollection"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Brak lub nieprawidłowy token"
                    },
                    "422": {
                        "description": "Błąd walidacji"
                    }
                },
                "security": [
                    {
                        "bearerAuth": [],
                        "worldHeader": []
                    }
                ]
            }
        },
        "/api/v1/maps/{mapId}": {
            "get": {
                "tags": [
                    "Maps"
                ],
                "summary": "Pobranie pojedynczej mapy",
                "operationId": "getMapById",
                "parameters": [
                    {
                        "name": "mapId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Szczegóły mapy",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/App\\Http\\Resources\\MapDetailResource"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Brak lub nieprawidłowy token"
                    },
                    "404": {
                        "description": "Mapa nie została znaleziona"
                    },
                    "422": {
                        "description": "Błąd walidacji"
                    }
                },
                "security": [
                    {
                        "bearerAuth": [],
                        "worldHeader": []
                    }
                ]
            }
        },
        "/api/v1/profile": {
            "get": {
                "tags": [
                    "Profile"
                ],
                "summary": "Pobranie profilu aktualnego użytkownika",
                "operationId": "getProfile",
                "responses": {
                    "200": {
                        "description": "Profil użytkownika",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/App\\Http\\Resources\\UserProfileResource"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Brak lub nieprawidłowy token"
                    }
                },
                "security": [
                    {
                        "bearerAuth": [],
                        "worldHeader": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "App\\Http\\Resources\\MapDetailResource": {
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "x": {
                        "type": "integer"
                    },
                    "y": {
                        "type": "integer"
                    },
                    "src": {
                        "type": "string"
                    },
                    "thumbnail_src": {
                        "type": "string"
                    },
                    "pvp": {
                        "type": "integer"
                    },
                    "battleground": {
                        "type": "string",
                        "nullable": true
                    },
                    "battleground2": {
                        "type": "string",
                        "nullable": true
                    },
                    "is_teleport_locked": {
                        "type": "boolean"
                    },
                    "respawn_point_id": {
                        "type": "integer",
                        "nullable": true
                    },
                    "water": {
                        "type": "string"
                    },
                    "col": {
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "App\\Http\\Resources\\MapListCollection": {
                "properties": {
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/App\\Http\\Resources\\MapListResource"
                        }
                    },
                    "meta": {
                        "$ref": "#/components/schemas/App\\OpenApi\\PaginationMeta"
                    }
                },
                "type": "object"
            },
            "App\\Http\\Resources\\MapListResource": {
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "x": {
                        "type": "integer"
                    },
                    "y": {
                        "type": "integer"
                    },
                    "src": {
                        "type": "string"
                    },
                    "thumbnail_src": {
                        "type": "string"
                    },
                    "pvp": {
                        "type": "integer"
                    },
                    "battleground": {
                        "type": "string",
                        "nullable": true
                    },
                    "battleground2": {
                        "type": "string",
                        "nullable": true
                    },
                    "is_teleport_locked": {
                        "type": "boolean"
                    },
                    "respawn_point_id": {
                        "type": "integer",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "App\\Http\\Resources\\PermissionResource": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "nullable": true
                    },
                    "name": {
                        "type": "string",
                        "nullable": true
                    },
                    "display_name": {
                        "type": "string",
                        "nullable": true
                    },
                    "description": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "App\\Http\\Resources\\RoleResource": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "nullable": true
                    },
                    "name": {
                        "type": "string",
                        "nullable": true
                    },
                    "display_name": {
                        "type": "string",
                        "nullable": true
                    },
                    "description": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "App\\Http\\Resources\\UserProfileResource": {
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "login": {
                        "type": "string"
                    },
                    "email": {
                        "type": "string",
                        "nullable": true
                    },
                    "roles": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/App\\Http\\Resources\\RoleResource"
                        }
                    },
                    "permissions": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/App\\Http\\Resources\\PermissionResource"
                        }
                    },
                    "forum_background_src": {
                        "type": "string",
                        "nullable": true
                    },
                    "src": {
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "App\\OpenApi\\PaginationMeta": {
                "properties": {
                    "current_page": {
                        "type": "integer"
                    },
                    "last_page": {
                        "type": "integer"
                    },
                    "per_page": {
                        "type": "integer"
                    },
                    "total": {
                        "type": "integer"
                    },
                    "from": {
                        "type": "integer",
                        "nullable": true
                    },
                    "to": {
                        "type": "integer",
                        "nullable": true
                    },
                    "world": {
                        "type": "string"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "API Token",
                "description": "Token do autoryzacji wygenerujesz w panelu użytkownika: Profil -> Tokeny API."
            },
            "worldHeader": {
                "type": "apiKey",
                "description": "Wymagany nagłówek świata. Dostępne wartości: retro, classic, legacy, demo.",
                "name": "X-World",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Maps",
            "description": "Maps"
        },
        {
            "name": "Profile",
